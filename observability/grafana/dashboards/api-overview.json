{
  "title": "CPG Platform - API Overview",
  "uid": "cpg-api-overview",
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"cpg-api\"}[1m])) by (handler)",
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "p95 latency by endpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"cpg-api\"}[5m])) by (le, handler))",
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Error rate (5xx) %",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "100 * sum(rate(http_requests_total{job=\"cpg-api\", status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"cpg-api\"}[5m]))",
          "legendFormat": "5xx %"
        }
      ]
    },
    {
      "id": 4,
      "title": "Total requests (1h)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(increase(http_requests_total{job=\"cpg-api\"}[1h]))",
          "legendFormat": "requests"
        }
      ]
    },
    {
      "id": 5,
      "title": "Status code breakdown",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(increase(http_requests_total{job=\"cpg-api\"}[1h])) by (status)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Request rate by handler (top 10)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "topk(10, sum(rate(http_requests_total{job=\"cpg-api\"}[5m])) by (handler))",
          "legendFormat": "{{handler}}"
        }
      ]
    }
  ]
}
